# ============================================================
# Echo · OpenAI-compatible LLM 配置
# ============================================================
# 复制本文件为 .env.local 并填入你的真实密钥
# Echo 采用"认接口不认厂商"设计，以下任一服务商均可：
#   DeepSeek:  https://api.deepseek.com/v1
#   Kimi:      https://api.moonshot.cn/v1
#   通义千问:  https://dashscope.aliyuncs.com/compatible-mode/v1
#   OpenAI:    https://api.openai.com/v1
#   智谱:      https://open.bigmodel.cn/api/paas/v4
#   百度千帆:  https://qianfan.baidubce.com/v2
# ============================================================

# 主文本模型（必填 · 用于过渡语/回归语/情绪聚合/修复引擎）
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
OPENAI_MODEL=glm-4.7-flashx

# 视觉模型（用于 /api/analyze 多模态场景分析，支持图片+视频理解）
OPENAI_VISION_MODEL=glm-5v-turbo

# 向量模型（用于品牌-场景语义匹配）
OPENAI_EMBEDDING_MODEL=embedding-3

# 长上下文模型（用于整集/多集离线剧情分析）
OPENAI_LONG_MODEL=glm-4-long

# ============================================================
# 智谱 GLM 可选模型清单
# ============================================================
# 文本：glm-5.1 / glm-5 / glm-5-turbo / glm-4.7 / glm-4.7-flashx(推荐) / glm-4.7-flash(免费)
# 视觉：glm-5v-turbo(推荐·支持视频) / glm-4.6v / glm-4v-flash(免费) / glm-4.6v-flash(免费)
# 向量：embedding-3 (256-2048维可选)
# 长文：glm-4-long (1M上下文)
# ============================================================

# 可选：强制降级为 Mock 数据（无 API Key 时自动启用）
# ECHO_USE_MOCK=true
